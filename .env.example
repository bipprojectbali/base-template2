# Database
DATABASE_URL=postgresql://user:password@localhost:5432/base-template
DIRECT_URL=postgresql://user:password@localhost:5432/base-template
# Used by `bun test` (NODE_ENV=test). Point at a SEPARATE database — the suite
# wipes tables on cleanup. Create + migrate it first: `DATABASE_URL=<this> bun run db:migrate`
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/base-template-test

# Dev Inspector
REACT_EDITOR=zed
PORT=3111
# Optional — Vite HMR WebSocket port (default 24678). Set jika bentrok dengan app lain.
HMR_PORT=24678

# Redis
REDIS_URL=redis://localhost:6379

# Claude Code Telegram Notification
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3111

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SUPER_ADMIN_EMAIL=admin@example.com

MCP_SECRET=

# STG Debug & Deploy (debug-stg + deploy-stg MCP servers)
STG_BASE_URL=
STG_MCP_SECRET=
STG_STACK_NAME=

# GitHub (deploy-stg MCP server)
# PAT dengan scope: repo + workflow
GH_TOKEN=
