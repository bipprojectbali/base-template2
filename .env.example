DIRECT_URL=postgresql://user:password@localhost:5432/base-template

# Dev Inspector
REACT_EDITOR=code
PORT=3000
HMR_PORT=24678

# Redis
REDIS_URL=redis://localhost:6379

# Claude Code Telegram Notification
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Better Auth
BETTER_AUTH_SECRET=
